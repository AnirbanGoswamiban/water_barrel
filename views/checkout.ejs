<!DOCTYPE html>
<html>
<head>
  <title>Checkout</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      padding: 20px;
      background: linear-gradient(135deg, #e0f7fa, #f5f5f5);
    }
    .box {
      background: white;
      padding: 25px;
      border-radius: 16px;
      max-width: 420px;
      margin: auto;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
    h2 {
      margin-bottom: 5px;
      color: #0077b6;
    }
    p {
      margin-bottom: 15px;
      color: #555;
    }
    input {
      width: 100%;
      padding: 11px;
      margin: 8px 0;
      border-radius: 10px;
      border: 1px solid #ccc;
      font-size: 14px;
    }
    .btn {
      width: 100%;
      padding: 11px;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      margin-top: 10px;
      cursor: pointer;
      color: white;
      background: linear-gradient(135deg, #007bff, #00b4d8);
      transition: 0.3s;
    }
    .btn:hover {
      background: linear-gradient(135deg, #0056b3, #0077b6);
    }
    .secondary {
      background: linear-gradient(135deg, #ff9800, #ff5722);
      font-weight: bold;
    }
    .secondary:hover {
      background: linear-gradient(135deg, #e65100, #bf360c);
    }
  </style>
</head>
<body>
<div class="box">
  <h2><%= product.name %></h2>
  <p>Price: ₹<%= product.price %></p>
  <input type="text" id="name" placeholder="Full Name" required>
  <input type="email" id="email" placeholder="Email" required>
  <label style="font-size:14px;font-weight:600;color:#333;">
    Delivery Location <span style="color:red">*</span>
  </label>
  <button type="button" class="btn secondary" onclick="getLocation()" id="locBtn">
    📍 Get My Live Location (Required)
  </button>
  <p id="locStatus" style="font-size:13px;margin-top:5px;"></p>
  <input type="hidden" id="lat">
  <input type="hidden" id="lng">
  <button class="btn" id="payBtn" disabled>Proceed to Pay</button>
</div>
<script>
function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}
function getLocation() {
  const status = document.getElementById("locStatus");
  if (navigator.geolocation) {
    status.innerText = "Fetching location...";
    status.style.color = "orange";
    navigator.geolocation.getCurrentPosition((pos) => {
      document.getElementById("lat").value = pos.coords.latitude;
      document.getElementById("lng").value = pos.coords.longitude;
      status.innerText = "✅ Location captured successfully";
      status.style.color = "green";
      document.getElementById("payBtn").disabled = false;
    }, () => {
      status.innerText = "❌ Location permission denied";
      status.style.color = "red";
    });
  } else {
    status.innerText = "❌ Geolocation not supported";
    status.style.color = "red";
  }
}
document.getElementById("payBtn").onclick = async () => {
  const name = document.getElementById("name").value;
  const email = document.getElementById("email").value;
  const lat = document.getElementById("lat").value;
  const lng = document.getElementById("lng").value;
  if (!name || !email) {
    alert("Name and email required");
    return;
  }
  if (!isValidEmail(email)) {
    alert("Invalid email");
    return;
  }
  if (!lat || !lng) {
    alert("Location is required for delivery");
    return;
  }
  const payBtn = document.getElementById("payBtn");
  payBtn.disabled = true;
  payBtn.innerText = "Processing...";
  const res = await fetch("/create-order", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      productId: "<%= product.id %>",
      name,
      email,
      lat,
      lng
    })
  });
  if (!res.ok) {
    alert("Something went wrong");
    payBtn.disabled = false;
    payBtn.innerText = "Proceed to Pay";
    return;
  }
  const data = await res.json();
  const options = {
    key: data.key,
    amount: data.amount * 100,
    currency: "INR",
    order_id: data.orderId,
    name: "Water Barrel Store",
    description: "<%= product.name %>",
    prefill: {
      name: name,
      email: email
    },
    handler: function () {
      alert("Payment successful!");
      window.location.href = "/";
    },
    modal: {
      ondismiss: function () {
        payBtn.disabled = false;
        payBtn.innerText = "Proceed to Pay";
        alert("Payment cancelled");
      }
    },
    theme: {
      color: "#0077b6"
    }
  };
  const rzp = new Razorpay(options);
  rzp.open();
};
</script>
</body>
</html>